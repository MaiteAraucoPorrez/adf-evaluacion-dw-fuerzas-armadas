{
	"name": "df_silver_efectivos",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_efectivos",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_efectivos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_efectivo as string,",
				"          id_especialidad as string,",
				"          id_unidad_actual as string,",
				"          id_rango_actual as string,",
				"          nombre as string,",
				"          ci as string,",
				"          fecha_nacimiento as string,",
				"          genero as string,",
				"          departamento_origen as string,",
				"          fecha_ingreso as string,",
				"          estado as string,",
				"          salario_mensual as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    TRIM(id_efectivo)        AS id_efectivo,\\n    TRIM(id_especialidad)    AS id_especialidad,\\n    TRIM(id_unidad_actual)   AS id_unidad_actual,\\n    TRIM(id_rango_actual)    AS id_rango_actual,\\n    TRIM(nombre)             AS nombre,\\n    TRIM(ci)                 AS ci,\\n    TRIM(fecha_nacimiento)   AS fecha_nacimiento,\\n    TRIM(genero)             AS genero,\\n    TRIM(departamento_origen) AS departamento_origen,\\n    TRIM(fecha_ingreso)      AS fecha_ingreso,\\n    TRIM(estado)             AS estado,\\n    TRIM(salario_mensual)    AS salario_mensual\\nFROM bronze.efectivos\\nWHERE TRIM(id_efectivo) IS NOT NULL AND TRIM(id_efectivo) <> \\'\\'',",
				"     format: 'query') ~> source1",
				"source1 derive(genero = iif(\r",
				"  in(['M','masculino','Masculino','MASCULINO','Hombre','hombre','HOMBRE','H','masc','Masc.','MASC'], trim(genero)), 'M',\r",
				"  iif(\r",
				"    in(['F','F.','femenino','Femenino','FEMENINO','Mujer','mujer','MUJER','fem','Fem.','FEM'], trim(genero)), 'F',\r",
				"    toString(null())\r",
				"  )\r",
				"),",
				"          estado = case(\r",
				"  in(['ACTIVO','ACT.','ACT','A','ACTV','EN ACTIVIDAD'], upper(trim(estado))), 'ACTIVO',\r",
				"\r",
				"  in(['BAJA','BJA','B','DADO DE BAJA'], upper(trim(estado))), 'BAJA',\r",
				"\r",
				"  in(['RESERVA','RSV','RSV.','R','EN RESERVA'], upper(trim(estado))), 'RESERVA',\r",
				"\r",
				"  toString(null())\r",
				"),",
				"          salario_mensual = toDecimal(\r",
				"    regexReplace(\r",
				"        regexReplace(\r",
				"            regexReplace(\r",
				"                regexReplace(\r",
				"                    toString(salario_mensual),\r",
				"                    '[Bb][Ss][\\\\.\\\\-\\\\s]*',\r",
				"                    ''\r",
				"                ),\r",
				"                '\\\\.(?=\\\\d{3})',\r",
				"                ''\r",
				"            ),\r",
				"            ',',\r",
				"            '.'\r",
				"        ),\r",
				"        '[^0-9\\\\.]',\r",
				"        ''\r",
				"    )\r",
				"),",
				"          fecha_nacimiento = coalesce(\r",
				"  toDate(fecha_nacimiento, 'yyyy-MM-dd'),\r",
				"  toDate(fecha_nacimiento, 'yyyy/MM/dd'),\r",
				"  toDate(fecha_nacimiento, 'dd-MM-yyyy'),\r",
				"  toDate(fecha_nacimiento, 'dd/MM/yyyy'),\r",
				"  toDate(fecha_nacimiento, 'MM/dd/yyyy')\r",
				"),",
				"          fecha_ingreso = coalesce(\r",
				"  toDate(fecha_ingreso, 'yyyy-MM-dd'),\r",
				"  toDate(fecha_ingreso, 'yyyy/MM/dd'),\r",
				"  toDate(fecha_ingreso, 'dd-MM-yyyy'),\r",
				"  toDate(fecha_ingreso, 'dd/MM/yyyy'),\r",
				"  toDate(fecha_ingreso, 'MM/dd/yyyy')\r",
				"),",
				"          departamento_origen = case(\r",
				"  in(['LA PAZ','LA PAZ ','LA  PAZ','LP','L.P.','LAPAZ','LPZ'], upper(trim(departamento_origen))), 'La Paz',\r",
				"\r",
				"  in(['COCHABAMBA','CBBA','CBBA.','COCHA'], upper(trim(departamento_origen))), 'Cochabamba',\r",
				"\r",
				"  in(['SANTA CRUZ','STA CRUZ','STA. CRUZ','SCZ','SC'], upper(trim(departamento_origen))), 'Santa Cruz',\r",
				"\r",
				"  in(['ORURO','OR.','OR'], upper(trim(departamento_origen))), 'Oruro',\r",
				"\r",
				"  in(['POTOSI','POTOSÍ','POT.','PT'], upper(trim(departamento_origen))), 'Potosí',\r",
				"\r",
				"  in(['CHUQUISACA','CHQ','CHQ.'], upper(trim(departamento_origen))), 'Chuquisaca',\r",
				"\r",
				"  in(['BENI','BN','BN.'], upper(trim(departamento_origen))), 'Beni',\r",
				"\r",
				"  in(['PANDO','PAN.'], upper(trim(departamento_origen))), 'Pando',\r",
				"\r",
				"  in(['TARIJA','TAR.','TJ'], upper(trim(departamento_origen))), 'Tarija',\r",
				"\r",
				"  in(['','NULL','-','N/D','S/D','SIN DATO'], upper(trim(departamento_origen))), toString(null()),\r",
				"\r",
				"  trim(departamento_origen)\r",
				"),",
				"          nombre = initCap(\r",
				"  trim(\r",
				"    regexReplace(\r",
				"      regexReplace(\r",
				"        regexReplace(nombre, '[\\\\\\\\#@\\\\*\\\\$\\\\!\\\\?\\\\|\\\\_\\\\-]+', ' '),\r",
				"        '\\\\s+',\r",
				"        ' '\r",
				"      ),\r",
				"      '[\\\\t\\\\n\\\\r]+',\r",
				"      ' '\r",
				"    )\r",
				"  )\r",
				"),",
				"          ci = upper(\r",
				"  trim(\r",
				"    replace(\r",
				"      replace(\r",
				"        replace(\r",
				"          replace(\r",
				"            replace(\r",
				"              replace(\r",
				"                replace(\r",
				"                  replace(\r",
				"                    ci,\r",
				"                    'LP', ' LP'\r",
				"                  ),\r",
				"                  'CB', ' CB'\r",
				"                ),\r",
				"                'SC', ' SC'\r",
				"              ),\r",
				"              'TJ', ' TJ'\r",
				"            ),\r",
				"            'OR', ' OR'\r",
				"          ),\r",
				"          'PT', ' PT'\r",
				"        ),\r",
				"        'CH', ' CH'\r",
				"      ),\r",
				"      'BN', ' BN'\r",
				"    )\r",
				"  )\r",
				")) ~> derivedColumn1",
				"derivedColumn1 derive(ci = regexReplace(\r",
				"  upper(\r",
				"    trim(\r",
				"      replace(\r",
				"        replace(\r",
				"          replace(\r",
				"            replace(\r",
				"              replace(\r",
				"                replace(\r",
				"                  replace(\r",
				"                    replace(\r",
				"                      ci,\r",
				"                      'LP', ' LP'\r",
				"                    ),\r",
				"                    'CB', ' CB'\r",
				"                  ),\r",
				"                  'SC', ' SC'\r",
				"                ),\r",
				"                'TJ', ' TJ'\r",
				"              ),\r",
				"              'OR', ' OR'\r",
				"            ),\r",
				"            'PT', ' PT'\r",
				"          ),\r",
				"          'CH', ' CH'\r",
				"        ),\r",
				"        'BN', ' BN'\r",
				"      )\r",
				"    )\r",
				"  ),\r",
				"  '\\\\s+',\r",
				"  ' '\r",
				")) ~> derivedColumn2",
				"derivedColumn2 derive(ci = case(\r",
				"\r",
				"  in(['ND','N/D','SD','S/D','SIN DATO','NULL','-',''], upper(trim(ci))),\r",
				"  toString(null()),\r",
				"\r",
				"  true(),\r",
				"\r",
				"  regexReplace(\r",
				"\r",
				"    upper(\r",
				"      trim(\r",
				"\r",
				"        replace(\r",
				"          replace(\r",
				"            replace(\r",
				"              replace(\r",
				"                replace(\r",
				"                  replace(\r",
				"                    replace(\r",
				"                      replace(\r",
				"\r",
				"                        replace(\r",
				"\r",
				"                          regexReplace(\r",
				"                            ci,\r",
				"                            'C\\\\.I\\\\.|CI\\\\:|CI',\r",
				"                            ''\r",
				"                          ),\r",
				"\r",
				"                          '-',\r",
				"                          ' '\r",
				"                        ),\r",
				"\r",
				"                        'LP', ' LP'\r",
				"                      ),\r",
				"                      'CB', ' CB'\r",
				"                    ),\r",
				"                    'SC', ' SC'\r",
				"                  ),\r",
				"                  'TJ', ' TJ'\r",
				"                ),\r",
				"                'OR', ' OR'\r",
				"              ),\r",
				"              'PT', ' PT'\r",
				"            ),\r",
				"            'CH', ' CH'\r",
				"          ),\r",
				"          'BN', ' BN'\r",
				"        )\r",
				"\r",
				"      )\r",
				"    ),\r",
				"\r",
				"    '\\\\s+',\r",
				"    ' '\r",
				"  )\r",
				"),",
				"          id_efectivo = toInteger(trim(id_efectivo)),",
				"          id_especialidad = toInteger(id_especialidad),",
				"          id_unidad_actual = toInteger(id_unidad_actual),",
				"          id_rango_actual = toInteger(id_rango_actual)) ~> derivedColumn3",
				"derivedColumn3 filter(!isNull(id_efectivo) && id_efectivo != 0) ~> filter1",
				"filter1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_efectivo as integer,",
				"          id_especialidad as integer,",
				"          id_unidad_actual as integer,",
				"          id_rango_actual as integer,",
				"          nombre as string,",
				"          ci as string,",
				"          fecha_nacimiento as date,",
				"          genero as string,",
				"          departamento_origen as string,",
				"          fecha_ingreso as date,",
				"          estado as string,",
				"          salario_mensual as decimal(18,2),",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_efectivo,",
				"          id_especialidad,",
				"          id_unidad_actual,",
				"          id_rango_actual,",
				"          nombre,",
				"          ci,",
				"          fecha_nacimiento,",
				"          genero,",
				"          departamento_origen,",
				"          fecha_ingreso,",
				"          estado,",
				"          salario_mensual",
				"     )) ~> sink1"
			]
		}
	}
}