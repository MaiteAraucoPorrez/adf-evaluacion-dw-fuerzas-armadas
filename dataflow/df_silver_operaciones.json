{
	"name": "df_silver_operaciones",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_operaciones",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_operaciones",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "aggregate1"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_operacion as string,",
				"          id_tipo as string,",
				"          id_unidad_resp as string,",
				"          id_zona as string,",
				"          nombre_operacion as string,",
				"          fecha_inicio as string,",
				"          fecha_fin as string,",
				"          efectivos_desplegados as string,",
				"          vehiculos_utilizados as string,",
				"          duracion_dias as string,",
				"          costo_operacion as string,",
				"          resultado as string,",
				"          detenidos as string,",
				"          area_km2 as string,",
				"          incidentes as string,",
				"          observaciones as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    TRIM(id_operacion)            AS id_operacion,\\n    TRIM(id_tipo)                 AS id_tipo,\\n    TRIM(id_unidad_resp)          AS id_unidad_resp,\\n    TRIM(id_zona)                 AS id_zona,\\n    TRIM(nombre_operacion)        AS nombre_operacion,\\n    TRIM(fecha_inicio)            AS fecha_inicio,\\n    TRIM(fecha_fin)               AS fecha_fin,\\n    TRIM(efectivos_desplegados)   AS efectivos_desplegados,\\n    TRIM(vehiculos_utilizados)    AS vehiculos_utilizados,\\n    TRIM(duracion_dias)           AS duracion_dias,\\n    TRIM(costo_operacion)         AS costo_operacion,\\n    TRIM(resultado)               AS resultado,\\n    TRIM(detenidos)               AS detenidos,\\n    TRIM(area_km2)                AS area_km2,\\n    TRIM(incidentes)              AS incidentes,\\n    TRIM(observaciones)           AS observaciones\\nFROM bronze.operaciones\\nWHERE TRIM(id_operacion) IS NOT NULL AND TRIM(id_operacion) <> \\'\\'',",
				"     format: 'query') ~> source1",
				"source1 derive(id_operacion = toInteger(id_operacion),",
				"          id_tipo = toInteger(id_tipo),",
				"          id_unidad_resp = toInteger(id_unidad_resp),",
				"          id_zona = toInteger(id_zona),",
				"          fecha_inicio = coalesce(\r",
				"  toDate(trim(fecha_inicio), 'yyyy-MM-dd'),\r",
				"  toDate(trim(fecha_inicio), 'yyyy/MM/dd'),\r",
				"  toDate(trim(fecha_inicio), 'dd-MM-yyyy'),\r",
				"  toDate(trim(fecha_inicio), 'dd/MM/yyyy')\r",
				"),",
				"          fecha_fin = coalesce(\r",
				"  toDate(trim(fecha_inicio), 'yyyy-MM-dd'),\r",
				"  toDate(trim(fecha_inicio), 'yyyy/MM/dd'),\r",
				"  toDate(trim(fecha_inicio), 'dd-MM-yyyy'),\r",
				"  toDate(trim(fecha_inicio), 'dd/MM/yyyy')\r",
				")) ~> derivedColumn1",
				"derivedColumn1 derive(costo_operacion = iif(\r",
				"  isNull(costo_operacion) || trim(toString(costo_operacion)) == '',\r",
				"  toDecimal(null()),\r",
				"  toDecimal(\r",
				"    regexReplace(toString(costo_operacion), '[^0-9\\\\.]', '')\r",
				"  )\r",
				"),",
				"          efectivos_desplegados = iif(\r",
				"  isNull(efectivos_desplegados) || trim(toString(efectivos_desplegados)) == '',\r",
				"  toInteger(null()),\r",
				"  toInteger(\r",
				"    regexReplace(toString(efectivos_desplegados), '[^0-9]', '')\r",
				"  )\r",
				"),",
				"          vehiculos_utilizados = iif(\r",
				"  isNull(vehiculos_utilizados) || trim(toString(vehiculos_utilizados)) == '',\r",
				"  toInteger(null()),\r",
				"  toInteger(\r",
				"    regexReplace(toString(vehiculos_utilizados), '[^0-9]', '')\r",
				"  )\r",
				"),",
				"          duracion_dias = iif(\r",
				"  isNull(duracion_dias) || trim(toString(duracion_dias)) == '',\r",
				"  toInteger(null()),\r",
				"  toInteger(\r",
				"    regexReplace(toString(duracion_dias), '[^0-9]', '')\r",
				"  )\r",
				"),",
				"          detenidos = iif(\r",
				"  isNull(detenidos) || trim(toString(detenidos)) == '',\r",
				"  toInteger(null()),\r",
				"  toInteger(\r",
				"    regexReplace(toString(detenidos), '[^0-9]', '')\r",
				"  )\r",
				"),",
				"          incidentes = iif(\r",
				"  isNull(incidentes) || trim(toString(incidentes)) == '',\r",
				"  toInteger(null()),\r",
				"  toInteger(\r",
				"    regexReplace(toString(incidentes), '[^0-9]', '')\r",
				"  )\r",
				"),",
				"          area_km2 = iif(\r",
				"  isNull(area_km2) || trim(toString(area_km2)) == '',\r",
				"  toDecimal(null()),\r",
				"  toDecimal(\r",
				"    regexReplace(toString(area_km2), '[^0-9\\\\.]', '')\r",
				"  )\r",
				"),",
				"          resultado = case(\r",
				"  in(['exitoso','exitosa','completado'], lower(trim(resultado))), 'EXITOSO',\r",
				"  in(['parcial','parcialmente'], lower(trim(resultado))), 'PARCIAL',\r",
				"  in(['fallido','sin resultado','fracasado'], lower(trim(resultado))), 'FALLIDO',\r",
				"  in(['en curso','en_curso','activo'], lower(trim(resultado))), 'EN CURSO',\r",
				"  upper(trim(regexReplace(resultado, '\\\\s+', ' ')))\r",
				"),",
				"          nombre_operacion = iif(\r",
				"    isNull(nombre_operacion) ||\r",
				"    trim(toString(nombre_operacion)) == '' ||\r",
				"    upper(trim(toString(nombre_operacion))) == 'NULL' ||\r",
				"    upper(trim(toString(nombre_operacion))) == 'N/A' ||\r",
				"    trim(toString(nombre_operacion)) == '-',\r",
				"\r",
				"    toString(null()),\r",
				"\r",
				"    iif(\r",
				"\r",
				"        startsWith(\r",
				"            regexReplace(\r",
				"                upper(trim(toString(nombre_operacion))),\r",
				"                '^OP\\\\s+',\r",
				"                'OPERACION '\r",
				"            ),\r",
				"            'OPERACION'\r",
				"        ),\r",
				"\r",
				"        regexReplace(\r",
				"            upper(trim(toString(nombre_operacion))),\r",
				"            '^OP\\\\s+',\r",
				"            'OPERACION '\r",
				"        ),\r",
				"\r",
				"        concat(\r",
				"            'OPERACION ',\r",
				"            upper(trim(toString(nombre_operacion)))\r",
				"        )\r",
				"\r",
				"    )\r",
				")) ~> derivedColumn2",
				"derivedColumn2 aggregate(groupBy(id_operacion),",
				"     id_tipo = first(id_tipo),",
				"          id_unidad_resp = first(id_unidad_resp),",
				"          id_zona = first(id_zona),",
				"          nombre_operacion = first(nombre_operacion),",
				"          fecha_inicio = first(fecha_inicio),",
				"          fecha_fin = first(fecha_fin),",
				"          efectivos_desplegados = first(efectivos_desplegados),",
				"          vehiculos_utilizados = first(vehiculos_utilizados),",
				"          duracion_dias = first(duracion_dias),",
				"          costo_operacion = first(costo_operacion),",
				"          resultado = first(resultado),",
				"          detenidos = first(detenidos),",
				"          area_km2 = first(area_km2),",
				"          incidentes = first(incidentes),",
				"          observaciones = first(observaciones)) ~> aggregate1",
				"aggregate1 filter(!isNull(id_operacion) && id_operacion > 0) ~> filter1",
				"filter1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_operacion as integer,",
				"          id_tipo as integer,",
				"          id_unidad_resp as integer,",
				"          id_zona as integer,",
				"          nombre_operacion as string,",
				"          fecha_inicio as date,",
				"          fecha_fin as date,",
				"          efectivos_desplegados as integer,",
				"          vehiculos_utilizados as integer,",
				"          duracion_dias as integer,",
				"          costo_operacion as decimal(18,2),",
				"          resultado as string,",
				"          detenidos as integer,",
				"          area_km2 as decimal(18,2),",
				"          incidentes as integer,",
				"          observaciones as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_operacion,",
				"          id_tipo,",
				"          id_unidad_resp,",
				"          id_zona,",
				"          nombre_operacion,",
				"          fecha_inicio,",
				"          fecha_fin,",
				"          efectivos_desplegados,",
				"          vehiculos_utilizados,",
				"          duracion_dias,",
				"          costo_operacion,",
				"          resultado,",
				"          detenidos,",
				"          area_km2,",
				"          incidentes,",
				"          observaciones",
				"     )) ~> sink1"
			]
		}
	}
}