{
	"name": "df_silver_movimientos_personal",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_movimientos_personal",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_movimientos_personal",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_movimiento as string,",
				"          id_efectivo as string,",
				"          id_unidad_destino as string,",
				"          id_rango as string,",
				"          id_tipo as string,",
				"          fecha_movimiento as string,",
				"          antiguedad_anios as string,",
				"          salario_mensual as string,",
				"          observaciones as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    TRIM(id_movimiento)     AS id_movimiento,\\n    TRIM(id_efectivo)       AS id_efectivo,\\n    TRIM(id_unidad_destino) AS id_unidad_destino,\\n    TRIM(id_rango)          AS id_rango,\\n    TRIM(id_tipo)           AS id_tipo,\\n    TRIM(fecha_movimiento)  AS fecha_movimiento,\\n    TRIM(antiguedad_anios)  AS antiguedad_anios,\\n    TRIM(salario_mensual)   AS salario_mensual,\\n    TRIM(observaciones)     AS observaciones\\nFROM bronze.movimientos_personal\\nWHERE TRIM(id_movimiento) IS NOT NULL AND TRIM(id_movimiento) <> \\'\\'',",
				"     format: 'query') ~> source1",
				"source1 derive(fecha_movimiento = coalesce(\r",
				"  toDate(fecha_movimiento, 'yyyy/MM/dd'),\r",
				"  toDate(fecha_movimiento, 'dd-MM-yyyy'),\r",
				"  toDate(fecha_movimiento, 'yyyy-MM-dd'),\r",
				"  toDate(fecha_movimiento, 'dd/MM/yyyy')\r",
				"),",
				"          antiguedad_anios = toDecimal(\r",
				"\r",
				"  regexReplace(\r",
				"\r",
				"    case(\r",
				"\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'cero'), '0',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'un año|uno'), '1',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'dos'), '2',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'tres'), '3',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'cuatro'), '4',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'cinco'), '5',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'seis'), '6',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'siete'), '7',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'ocho'), '8',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'nueve'), '9',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'diez'), '10',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'once'), '11',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'doce'), '12',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'trece'), '13',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'catorce'), '14',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'quince'), '15',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'dieciseis|dieciséis'), '16',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'diecisiete'), '17',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'dieciocho'), '18',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'diecinueve'), '19',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'veinte'), '20',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'veintiuno'), '21',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'veintidos|veintidós'), '22',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'veintitres|veintitrés'), '23',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'veinticuatro'), '24',\r",
				"      regexMatch(lower(trim(toString(antiguedad_anios))), 'veinticinco'), '25',\r",
				"\r",
				"      true(),\r",
				"      toString(antiguedad_anios)\r",
				"\r",
				"    ),\r",
				"\r",
				"    '[^0-9\\\\.]',\r",
				"    ''\r",
				"\r",
				"  )\r",
				"\r",
				"),",
				"          salario_mensual = toDecimal(\r",
				"  regexReplace(\r",
				"    regexReplace(toString(salario_mensual), '[Bb][Ss][\\\\.\\\\-\\\\s]*', ''),\r",
				"  '[^0-9\\\\.,]', '')\r",
				"),",
				"          id_movimiento = toInteger(id_movimiento),",
				"          id_efectivo = toInteger(id_efectivo),",
				"          id_unidad_destino = toInteger(id_unidad_destino),",
				"          id_rango = toInteger(id_rango),",
				"          id_tipo = toInteger(id_tipo)) ~> derivedColumn1",
				"derivedColumn1 filter(!isNull(id_movimiento) && id_movimiento > 0) ~> filter1",
				"filter1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_movimiento as integer,",
				"          id_efectivo as integer,",
				"          id_unidad_destino as integer,",
				"          id_rango as integer,",
				"          id_tipo as integer,",
				"          fecha_movimiento as date,",
				"          antiguedad_anios as decimal(5,1),",
				"          salario_mensual as decimal(18,2),",
				"          observaciones as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_movimiento,",
				"          id_efectivo,",
				"          id_unidad_destino,",
				"          id_rango,",
				"          id_tipo,",
				"          fecha_movimiento,",
				"          antiguedad_anios,",
				"          salario_mensual,",
				"          observaciones",
				"     )) ~> sink1"
			]
		}
	}
}