{
	"name": "df_hechos_operaciones",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_operaciones",
						"type": "DatasetReference"
					},
					"name": "silverOperaciones"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_unidad",
						"type": "DatasetReference"
					},
					"name": "goldDimUnidad"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_tipo_operacion",
						"type": "DatasetReference"
					},
					"name": "goldDimTipoOperacion"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_zona",
						"type": "DatasetReference"
					},
					"name": "goldDimZona"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_hechos_operaciones",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "lookup1"
				},
				{
					"name": "lookup2"
				},
				{
					"name": "lookup3"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_operacion as integer,",
				"          id_tipo as integer,",
				"          id_unidad_resp as integer,",
				"          id_zona as integer,",
				"          nombre_operacion as string,",
				"          fecha_inicio as date,",
				"          fecha_fin as date,",
				"          efectivos_desplegados as integer,",
				"          vehiculos_utilizados as integer,",
				"          duracion_dias as integer,",
				"          costo_operacion as decimal(18,2),",
				"          resultado as string,",
				"          detenidos as integer,",
				"          area_km2 as decimal(18,2),",
				"          incidentes as integer,",
				"          observaciones as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> silverOperaciones",
				"source(output(",
				"          unidad_key as integer,",
				"          id_unidad as integer,",
				"          nombre as string,",
				"          codigo as string,",
				"          ciudad as string,",
				"          departamento as string,",
				"          tipo_cuartel as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> goldDimUnidad",
				"source(output(",
				"          tipo_op_key as integer,",
				"          id_tipo as integer,",
				"          nombre as string,",
				"          categoria as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> goldDimTipoOperacion",
				"source(output(",
				"          zona_key as integer,",
				"          id_zona as integer,",
				"          nombre as string,",
				"          departamento as string,",
				"          frontera_con as string,",
				"          tipo_terreno as string,",
				"          nivel_riesgo as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> goldDimZona",
				"silverOperaciones, goldDimUnidad lookup(id_unidad_resp == id_unidad,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"lookup1, goldDimTipoOperacion lookup(silverOperaciones@id_tipo == goldDimTipoOperacion@id_tipo,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup2",
				"lookup2, goldDimZona lookup(silverOperaciones@id_zona == goldDimZona@id_zona,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup3",
				"lookup3 derive(fecha_inicio_key = toInteger(toString(fecha_inicio, 'yyyyMMdd')),",
				"          fecha_fin_key = toInteger(toString(fecha_fin, 'yyyyMMdd')),",
				"          id_operacion_origen = id_operacion) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          efectivos_desplegados,",
				"          vehiculos_utilizados,",
				"          duracion_dias,",
				"          costo_operacion,",
				"          resultado,",
				"          detenidos,",
				"          area_km2,",
				"          incidentes,",
				"          unidad_key,",
				"          tipo_op_key,",
				"          zona_key,",
				"          fecha_inicio_key,",
				"          fecha_fin_key,",
				"          id_operacion_origen",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          operacion_key as integer,",
				"          fecha_inicio_key as integer,",
				"          fecha_fin_key as integer,",
				"          unidad_key as integer,",
				"          tipo_op_key as integer,",
				"          zona_key as integer,",
				"          efectivos_desplegados as integer,",
				"          vehiculos_utilizados as integer,",
				"          duracion_dias as integer,",
				"          costo_operacion as decimal(18,2),",
				"          detenidos as integer,",
				"          area_km2 as decimal(18,2),",
				"          incidentes as integer,",
				"          resultado as string,",
				"          id_operacion_origen as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          fecha_inicio_key,",
				"          fecha_fin_key,",
				"          unidad_key,",
				"          tipo_op_key,",
				"          zona_key,",
				"          efectivos_desplegados,",
				"          vehiculos_utilizados,",
				"          duracion_dias,",
				"          costo_operacion,",
				"          detenidos,",
				"          area_km2,",
				"          incidentes,",
				"          resultado,",
				"          id_operacion_origen",
				"     )) ~> sink1"
			]
		}
	}
}